# 复用现有 DB 配置（与 apps/api 同库）
DATABASE_URL=postgresql://user:pass@localhost:5432/emotion_companion
DATABASE_SSL=true

# Admin 专用
ADMIN_PORT=3001
ADMIN_HOST=0.0.0.0
# 至少 32 位随机字符串，例如 `openssl rand -hex 32`
ADMIN_TOKEN=change-me-please-at-least-32-characters
ADMIN_CORS_ORIGIN=http://localhost:5174
LOG_LEVEL=info

# 转发给 health 检查（apps/api 的 /api/health）
API_BASE_URL=http://localhost:3000

NODE_ENV=development
