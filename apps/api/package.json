{
  "name": "@emotion/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@emotion/shared": "workspace:*",
    "@emotion/safety": "workspace:*",
    "@emotion/core-ai": "workspace:*",
    "@emotion/memory": "workspace:*",
    "@emotion/analytics": "workspace:*",
    "@emotion/skill-emotion-intake": "workspace:*",
    "@emotion/skill-companion-response": "workspace:*",
    "@emotion/skill-safety-triage": "workspace:*",
    "@emotion/skill-tong-analysis": "workspace:*",
    "@emotion/skill-message-coach": "workspace:*",
    "@emotion/skill-recovery-plan": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
