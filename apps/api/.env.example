# ===== AI =====
ANTHROPIC_API_KEY=
# 可选：自定义 Anthropic API 入口（代理 / 中转 / 私有网关）。
# 留空则使用官方 https://api.anthropic.com
# 例：ANTHROPIC_BASE_URL=https://api.anthropic-proxy.example.com
ANTHROPIC_BASE_URL=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024
INTAKE_TIMEOUT_MS=10000
SKILL_TIMEOUT_MS=90000

# ===== Supabase 连接串。本地开发也直连云端 =====
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_SSL=true

# Upstash Redis（Phase 1 暂未启用，预留供 Phase 2+ 使用）
REDIS_URL=

JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# 允许过期 token 在该秒数窗口内刷新（默认 30 天）
JWT_REFRESH_GRACE_SECONDS=2592000

PORT=3000
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MAX_REQUESTS_PER_MINUTE=60
ENABLE_SAFETY_GUARD=true
LOG_LEVEL=info
