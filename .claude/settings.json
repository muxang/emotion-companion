{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm run dev)",
      "Bash(pnpm run test)",
      "Bash(pnpm run build)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run lint:fix)",
      "Bash(pnpm --filter api run dev)",
      "Bash(pnpm --filter web run dev)",
      "Bash(pnpm --filter api run test)",
      "Bash(pnpm --filter web run test)",
      "Bash(pnpm --filter api run build)",
      "Bash(pnpm --filter web run build)",
      "Bash(pnpm --filter api run db:migrate)",
      "Bash(docker compose -f infra/docker-compose.yml up -d)",
      "Bash(docker compose -f infra/docker-compose.yml down)",
      "Bash(docker compose -f infra/docker-compose.prod.yml up -d)",
      "Bash(docker compose -f infra/docker-compose.prod.yml down)",
      "Read(./docs/**)",
      "Read(./apps/**)",
      "Read(./packages/**)",
      "Read(./infra/**)",
      "Read(./tests/**)",
      "Read(./CLAUDE.md)",
      "Read(./package.json)",
      "Read(./pnpm-workspace.yaml)",
      "Read(./tsconfig.base.json)",
      "Edit(./apps/**)",
      "Edit(./packages/**)",
      "Edit(./docs/**)",
      "Edit(./tests/**)",
      "Edit(./infra/**)",
      "Edit(./CLAUDE.md)",
      "Edit(./package.json)",
      "Edit(./pnpm-workspace.yaml)",
      "Edit(./tsconfig.base.json)",
      "Write(./apps/**)",
      "Write(./packages/**)",
      "Write(./docs/**)",
      "Write(./tests/**)",
      "Write(./infra/**)",
      "Write(./CLAUDE.md)",
      "Write(./package.json)",
      "Write(./pnpm-workspace.yaml)",
      "Write(./tsconfig.base.json)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.*.local)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./*.pem)",
      "Read(./**/*.pem)",
      "Read(./*.key)",
      "Read(./**/*.key)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.*.local)",
      "Edit(./**/.env)",
      "Edit(./**/.env.local)",
      "Edit(./**/.env.*.local)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.*.local)",
      "Write(./**/.env)",
      "Write(./**/.env.local)",
      "Write(./**/.env.*.local)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm install -g *)",
      "Bash(pnpm add -g *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)"
    ]
  }
}