# ============================================================
# Production .env for emotion-companion API
# ============================================================
# 这个文件由 setup.sh 拷贝到 apps/api/.env，但带有占位符。
# 在第一次启动服务前，必须用 nano 编辑替换所有 __FILL_ME__ / __PLACEHOLDER__ 项。
#
# 编辑命令：
#   sudo -u __APP_USER__ nano __APP_DIR__/apps/api/.env
#
# setup.sh 完成后会自动检测占位符是否已填写，未填写则不会启动服务。
# ============================================================

NODE_ENV=production

# ---------- AI ----------
ANTHROPIC_API_KEY=__FILL_ME__
# 留空使用 https://api.anthropic.com 官方端点；
# 如果用中转代理，填完整 URL，例如 https://your-proxy.example.com
ANTHROPIC_BASE_URL=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024
INTAKE_TIMEOUT_MS=10000

# ---------- Supabase Postgres ----------
DATABASE_URL=__FILL_ME__
DATABASE_SSL=true

# ---------- Upstash Redis（可选，留空降级为内存 store）----------
REDIS_URL=

# ---------- JWT ----------
# JWT_SECRET 由 setup.sh 自动生成，已经是强随机串
JWT_SECRET=__JWT_SECRET_PLACEHOLDER__
JWT_EXPIRES_IN=7d
JWT_REFRESH_GRACE_SECONDS=2592000

# ---------- 服务端 ----------
# 只监听 127.0.0.1，由 Nginx 反代到外网
HOST=127.0.0.1
PORT=__NODE_PORT__
# 必须等于前端最终域名（含 https://，不要带尾斜杠）
CORS_ORIGIN=__CORS_ORIGIN_FILL_ME__
MAX_REQUESTS_PER_MINUTE=60
ENABLE_SAFETY_GUARD=true
LOG_LEVEL=info
